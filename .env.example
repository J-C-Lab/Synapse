# Public env vars exposed to the renderer — MUST start with VITE_.
# Access in renderer code via `import.meta.env.VITE_APP_NAME`.
VITE_APP_NAME="FluxBox"

# Main-process env vars (read via process.env in src/main/**). Not exposed
# to the renderer. Add secrets below as the project grows.
# DATABASE_URL=
# UPDATER_FEED_URL=
