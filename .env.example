# Public env vars exposed to the renderer — MUST start with VITE_.
# Access in renderer code via `import.meta.env.VITE_APP_NAME`.
VITE_APP_NAME="FluxBox"

# GitHub OAuth App client ID for the bundled GitHub Inbox plugin (PKCE; no secret).
# Register at https://github.com/settings/developers — Authorization callback URL: http://127.0.0.1
# SYNAPSE_GITHUB_OAUTH_CLIENT_ID=
