# Marketplace server configuration. Copy to .env for local dev.

# HTTP
PORT=8787
HOST=0.0.0.0
# Public origin used to build user-facing URLs (device verification page).
PUBLIC_BASE_URL=http://localhost:8787

# Database — Neon (or any Postgres). Required to start the server / run migrations.
DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require

# GitHub OAuth app credentials. Required to start the server.
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# Per-IP rate limiting (on by default). RATE_LIMIT_MAX is the global per-minute
# ceiling; auth and publish routes apply their own tighter limits on top.
RATE_LIMIT_ENABLED=true
RATE_LIMIT_MAX=300

# The programmatic /auth/device/approve endpoint skips the browser leg. Leave
# OFF in production — the GitHub OAuth callback is the only approval path there.
# Enable only for local/non-browser testing.
ENABLE_DEVICE_APPROVE_ENDPOINT=false
