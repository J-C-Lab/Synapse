{
  "$schema": "https://unpkg.com/@deskit/plugin-manifest/schema/deskit-manifest.schema.json",
  "id": "com.example.hello-world",
  "name": "hello-world",
  "displayName": { "en": "Hello World", "zh-CN": "你好世界" },
  "description": {
    "en": "A starter DesKit plugin.",
    "zh-CN": "一个 DesKit 插件起步模板。"
  },
  "version": "0.1.0",
  "author": "Your Name",
  "engines": { "deskit": "^0.2.0" },
  "main": "dist/index.js",
  "contributes": {
    "commands": [
      {
        "id": "hello.world",
        "title": { "en": "Say Hello", "zh-CN": "打招呼" },
        "subtitle": { "en": "A starter command", "zh-CN": "起步命令" },
        "mode": "view"
      }
    ]
  },
  "permissions": []
}
