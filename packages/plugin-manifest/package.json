{
  "name": "@deskit/plugin-manifest",
  "version": "0.1.0",
  "description": "DesKit plugin manifest schema, validation, and engine-compatibility helpers — shared by the DesKit host and the plugin CLI",
  "license": "MIT",
  "sideEffects": false,
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "README.md",
    "dist",
    "src"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@deskit/plugin-sdk": "workspace:*",
    "zod": "^4.4.3"
  },
  "publishConfig": {
    "access": "public"
  }
}
