{
  "$schema": "https://unpkg.com/@synapse/plugin-manifest/schema/synapse-manifest.schema.json",
  "id": "com.example.hello-world",
  "name": "hello-world",
  "displayName": { "en": "Hello World", "zh-CN": "你好世界" },
  "description": {
    "en": "A starter Synapse plugin.",
    "zh-CN": "一个 Synapse 插件起步模板。"
  },
  "version": "0.1.0",
  "author": "Your Name",
  "engines": { "synapse": "^0.2.0" },
  "main": "dist/index.js",
  "contributes": {
    "commands": [
      {
        "id": "hello.world",
        "title": { "en": "Say Hello", "zh-CN": "打招呼" },
        "subtitle": { "en": "A starter command", "zh-CN": "起步命令" },
        "mode": "view"
      }
    ],
    "tools": [
      {
        "name": "greet",
        "title": { "en": "Greet", "zh-CN": "问候" },
        "description": "Return a friendly greeting for the given name. Read-only; safe to call without confirmation.",
        "inputSchema": {
          "type": "object",
          "properties": {
            "name": {
              "type": "string",
              "description": "The name to greet."
            }
          },
          "required": ["name"]
        },
        "outputSchema": {
          "type": "object",
          "properties": {
            "greeting": { "type": "string" }
          },
          "required": ["greeting"]
        },
        "annotations": { "readOnlyHint": true }
      }
    ]
  },
  "permissions": []
}
