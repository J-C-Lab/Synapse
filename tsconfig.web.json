{
  "compilerOptions": {
    "composite": true,
    "target": "ES2022",
    "jsx": "react-jsx",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "baseUrl": ".",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "paths": {
      "@/*": ["./src/renderer/src/*"],
      "@synapse/plugin-sdk": ["./packages/plugin-sdk/src/index.ts"],
      "@synapse/marketplace-types": ["./packages/marketplace-types/src/index.ts"],
      "@synapse/plugin-manifest": ["./packages/plugin-manifest/src/index.ts"]
    },
    "resolveJsonModule": true,
    "types": ["vite/client", "@testing-library/jest-dom"],
    "strict": true,
    "noEmit": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "isolatedModules": true,
    "skipLibCheck": true
  },
  "include": [
    "src/renderer/src/**/*",
    "src/preload/index.d.ts",
    "packages/plugin-sdk/src/**/*",
    "packages/plugin-manifest/src/**/*",
    "packages/marketplace-types/src/**/*"
  ],
  "exclude": [
    "packages/plugin-sdk/src/__examples__/**",
    "packages/plugin-manifest/src/**/*.test.ts",
    "packages/marketplace-types/src/**/*.test.ts"
  ]
}
