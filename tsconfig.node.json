{
  "compilerOptions": {
    "composite": true,
    "target": "ES2022",
    "lib": ["ES2022"],
    "baseUrl": ".",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "paths": {
      "@synapse/plugin-sdk": ["./packages/plugin-sdk/src/index.ts"],
      "@synapse/plugin-manifest": ["./packages/plugin-manifest/src/index.ts"],
      "@synapse/marketplace-types": ["./packages/marketplace-types/src/index.ts"],
      "@synapse/agent-protocol": ["./packages/agent-protocol/src/index.ts"],
      "@main/*": ["./src/main/*"],
      "@preload/*": ["./src/preload/*"]
    },
    "resolveJsonModule": true,
    "types": ["node", "electron-vite/node"],
    "strict": true,
    "noEmit": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "isolatedModules": true,
    "skipLibCheck": true
  },
  "include": [
    "src/main/**/*",
    "src/preload/**/*",
    "packages/plugin-sdk/src/**/*",
    "packages/plugin-manifest/src/**/*",
    "packages/marketplace-types/src/**/*",
    "packages/agent-protocol/src/**/*",
    "electron.vite.config.ts"
  ],
  "exclude": ["packages/plugin-sdk/src/__examples__/**"]
}
