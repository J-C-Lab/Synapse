{
  "name": "synapse",
  "version": "0.3.0",
  "private": true,
  "packageManager": "pnpm@11.0.8",
  "description": "Synapse — desktop productivity toolbox (Electron + React + electron-vite)",
  "author": "Synapse Team <1397784681@qq.com>",
  "license": "MIT",
  "main": "out/main/index.js",
  "engines": {
    "node": ">=22.13.0"
  },
  "scripts": {
    "prepare": "husky",
    "dev": "electron-vite dev",
    "dev:lan:a": "cross-env SYNAPSE_LAN_SIMULATION_PROFILE=a electron-vite dev",
    "dev:lan:b": "cross-env SYNAPSE_LAN_SIMULATION_PROFILE=b electron-vite dev",
    "build": "pnpm build:packages && electron-vite build",
    "build:sdk": "pnpm -F @synapsepkg/plugin-sdk build",
    "build:manifest": "pnpm -F @synapsepkg/plugin-manifest build",
    "build:marketplace-types": "pnpm -F @synapsepkg/marketplace-types build",
    "build:packages": "pnpm build:sdk && pnpm build:manifest && pnpm build:marketplace-types",
    "preview": "electron-vite preview",
    "start": "electron-vite preview",
    "typecheck": "pnpm build:packages && pnpm -F @synapsepkg/plugin-sdk typecheck && pnpm -F @synapsepkg/plugin-manifest typecheck && pnpm -F @synapsepkg/marketplace-types typecheck && pnpm -F @synapsepkg/marketplace-server typecheck && pnpm -F @synapsepkg/plugin-cli typecheck && pnpm -F create-synapse-plugin typecheck && tsc -p tsconfig.node.json --noEmit && tsc -p tsconfig.web.json --noEmit",
    "typecheck:native": "tsgo -p tsconfig.node.json --noEmit && tsgo -p tsconfig.web.json --noEmit",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "eval": "vitest run --config vitest.eval.config.ts",
    "eval:judged": "vitest run --config vitest.eval.config.ts",
    "test:e2e": "pnpm build && playwright test --project=development",
    "test:e2e:packaged": "cross-env SYNAPSE_PACKAGED_EXE=release/win-unpacked/Synapse.exe playwright test --project=packaged",
    "electron:build": "electron-vite build && electron-builder",
    "electron:build:win": "electron-vite build && electron-builder --win",
    "electron:build:mac": "electron-vite build && electron-builder --mac",
    "electron:build:linux": "electron-vite build && electron-builder --linux",
    "docs:dev": "pnpm -F docs dev",
    "docs:build": "pnpm -F docs build",
    "docs:start": "pnpm -F docs start",
    "icons": "node scripts/build-icons.cjs"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.100.1",
    "@base-ui/react": "^1.0.0",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@radix-ui/react-slot": "^1.2.4",
    "@synapsepkg/plugin-manifest": "workspace:*",
    "bonjour-service": "1.3.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "date-fns": "^4.1.0",
    "electron-updater": "^6.8.9",
    "embla-carousel-react": "^8.5.1",
    "i18next": "^25.0.0",
    "input-otp": "^1.4.1",
    "lucide-react": "^0.460.0",
    "next-themes": "^0.4.6",
    "openai": "^6.41.0",
    "radix-ui": "^1.4.3",
    "react": "^19.2.5",
    "react-day-picker": "^9.6.2",
    "react-dom": "^19.2.5",
    "react-hook-form": "^7.54.2",
    "react-i18next": "^15.2.0",
    "react-markdown": "^10.1.0",
    "react-resizable-panels": "^2.1.7",
    "recharts": "^2.15.0",
    "remark-gfm": "^4.0.1",
    "selfsigned": "3.0.1",
    "shiki": "^4.2.0",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.5.0",
    "vaul": "^1.1.2",
    "yauzl": "2.10.0",
    "zod": "^4.4.3",
    "zustand": "^5.0.13"
  },
  "devDependencies": {
    "@antfu/eslint-config": "latest",
    "@commitlint/cli": "^20.5.3",
    "@commitlint/config-conventional": "^20.5.3",
    "@eslint-react/eslint-plugin": "^5.8.3",
    "@playwright/test": "^1.61.1",
    "@tailwindcss/typography": "^0.5.19",
    "@tailwindcss/vite": "^4.2.4",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^22.19.17",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/yauzl": "2.10.3",
    "@typescript/native-preview": "latest",
    "@vitejs/plugin-react": "^4.3.4",
    "@vitest/coverage-v8": "^2.1.8",
    "cross-env": "^7.0.3",
    "electron": "^43.1.0",
    "electron-builder": "^26.15.3",
    "electron-vite": "^3.0.0",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-react-refresh": "^0.5.2",
    "husky": "^9.1.7",
    "js-yaml": "^4.1.1",
    "jsdom": "^25.0.1",
    "lint-staged": "^15.5.2",
    "png2icons": "^2.0.1",
    "prettier": "^3.8.3",
    "shadcn": "^4.7.0",
    "sharp": "^0.34.5",
    "tailwindcss": "^4.2.4",
    "tw-animate-css": "^1.4.0",
    "typescript": "^5.9.3",
    "vite": "^6.0.0",
    "vitest": "^2.1.8"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,css,md,mdx}": [
      "prettier --write"
    ]
  },
  "build": {
    "appId": "com.synapse.desktop",
    "productName": "Synapse",
    "asar": true,
    "npmRebuild": false,
    "buildDependenciesFromSource": false,
    "nodeGypRebuild": false,
    "publish": [
      {
        "provider": "github",
        "owner": "sunzrnobug",
        "repo": "Synapse"
      }
    ],
    "directories": {
      "output": "release",
      "buildResources": "resources"
    },
    "fileAssociations": [
      {
        "ext": "syn",
        "name": "Synapse Plugin",
        "description": "Synapse plugin package",
        "role": "Viewer"
      }
    ],
    "files": [
      "out/**/*",
      "resources/**/*",
      "package.json",
      "!**/*.{md,markdown,test.ts,test.tsx,spec.ts,spec.tsx,map}",
      "!{.eslintrc,.prettierrc,.editorconfig,.gitignore,.gitattributes}",
      "!**/__mocks__/**",
      "!**/__tests__/**"
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "msi",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "resources/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "artifactName": "${productName}-Setup-${version}.${ext}"
    },
    "msi": {
      "artifactName": "${productName}-${version}.${ext}"
    },
    "mac": {
      "target": [
        {
          "target": "dmg",
          "arch": [
            "x64",
            "arm64"
          ]
        },
        {
          "target": "zip",
          "arch": [
            "x64",
            "arm64"
          ]
        }
      ],
      "icon": "resources/icon.icns",
      "category": "public.app-category.productivity"
    },
    "linux": {
      "target": [
        {
          "target": "AppImage",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "deb",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "resources/icon.png",
      "category": "Utility"
    }
  }
}
